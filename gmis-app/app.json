{
  "expo": {
    "name": "GMIS",
    "slug": "gmis-app",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "scheme": "gmis",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#03071a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.gmis.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "GMIS needs camera access to scan QR codes for attendance.",
        "NSPhotoLibraryUsageDescription": "GMIS needs photo access to update your profile picture.",
        "NSPhotoLibraryAddUsageDescription": "GMIS needs photo access to save images.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#03071a"
      },
      "package": "app.gmis.mobile",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/gmis_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#2d6cff",
          "defaultChannel": "gmis-general",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "GMIS needs camera access to scan QR codes for attendance."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GMIS needs photo access to update your profile picture."
        }
      ],
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/YOUR_EAS_PROJECT_ID",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "owner": "damstech"
  }
}
