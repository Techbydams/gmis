{
  "expo": {
    "name": "GMIS",
    "slug": "gmis-app",
    "version": "1.0.0",
    "scheme": "gmis",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.damstech.gmis"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#03071a"
      },
      "package": "com.damstech.gmis"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "GMIS needs camera access to scan QR codes for attendance."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GMIS needs photo access to update your profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
