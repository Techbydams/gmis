# ============================================================
# GMIS — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!
# ============================================================

# ── MASTER SUPABASE (gmis.com platform database) ──────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── LOCAL DEV ONLY ─────────────────────────────────────────
# Set this to simulate being on a school's subdomain locally
# e.g. VITE_DEV_TENANT_SLUG=estam  will behave like estam.gmis.com
VITE_DEV_TENANT_SLUG=

# ── APP CONFIG ─────────────────────────────────────────────
VITE_APP_NAME=GMIS
VITE_APP_DOMAIN=gmis.com
VITE_APP_ENV=development
